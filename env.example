# ============================================================
# AI Orchestrator v2 — 환경변수 예시
# 이 파일을 복사해서 .env로 저장 후 실제 값 입력
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# OpenRouter — planner / builder / doc / reviewer (필수)
# ------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-여기에입력

# 역할별 모델 (기본값: openrouter/auto)
OPENROUTER_PLANNER_MODEL=openai/gpt-5.4
OPENROUTER_BUILDER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_DOC_MODEL=openai/gpt-5.4-mini
OPENROUTER_REVIEWER_MODEL=openai/gpt-5.4-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PLANNER_REASONING_EFFORT=high
OPENROUTER_BUILDER_VERBOSITY=high

# ------------------------------------------------------------
# Research — 핵심 축
# ------------------------------------------------------------

# Gemini (googleSearch grounding + Deep Research) — 권장
GEMINI_API_KEY=AIza여기에입력

# Gemini Deep Research (Interactions API)
GEMINI_DEEP_RESEARCH_AGENT=deep-research-pro-preview-12-2025
GEMINI_DEEP_RESEARCH_TIMEOUT=600.0
GEMINI_DEEP_RESEARCH_POLL_INTERVAL=10.0
GEMINI_DEEP_RESEARCH_MAX_CLAIMS=10

# GPT Deep Research (OpenAI Responses API)
OPENAI_API_KEY=sk-여기에입력
GPT_RESEARCH_MODEL=openai/o4-mini-deep-research
GPT_RESEARCH_TIMEOUT=120.0
GPT_RESEARCH_MAX_TOKENS=2000

# ------------------------------------------------------------
# Research — support
# ------------------------------------------------------------

# Perplexity (웹 보강)
PERPLEXITY_API_KEY=pplx-여기에입력
PERPLEXITY_MODEL=sonar

# Brave (선택)
# BRAVE_SEARCH_API_KEY=bsk-여기에입력

# YouTube (fallback stub — 기본 활성, 끄려면 disabled)
# YOUTUBE_TRANSCRIPT_MODE=disabled

# ------------------------------------------------------------
# Cursor 자동 실행 (선택)
# ------------------------------------------------------------
CURSOR_AUTO_MODE=false
# CURSOR_API_KEY=cursor-여기에입력
# CURSOR_REPO_PATH=C:\Users\...\ai-orchestrator-v1
# CURSOR_EXECUTION_TIMEOUT=600.0
# CURSOR_POLL_INTERVAL=10.0
